{
  "expo": {
    "name": "PixieSketch AI",
    "slug": "pixiesketch-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "pixiesketch",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pixiesketch.ai",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "PixieSketch needs camera access to capture your drawings",
        "NSPhotoLibraryUsageDescription": "PixieSketch needs photo library access to select your drawings",
        "NSPhotoLibraryAddUsageDescription": "PixieSketch needs permission to save transformed artwork to your photos"
      }
    },
    "android": {
      "package": "com.pixiesketch.ai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PixieSketch to access your camera to capture drawings"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PixieSketch to access your photos to select drawings"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "pixiesketch-ai"
      },
      "router": {
        "origin": false
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}

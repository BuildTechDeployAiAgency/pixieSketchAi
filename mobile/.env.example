# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter AI (for direct client-side calls - optional)
EXPO_PUBLIC_OPENROUTER_API_KEY=your-openrouter-api-key

# Stripe (for payment links)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# RevenueCat (for in-app purchases - optional)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-ios-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-android-key
